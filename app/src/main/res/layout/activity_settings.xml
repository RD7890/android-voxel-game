<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_menu"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_back"
                android:background="@color/btn_gray"
                android:padding="8dp"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_gold"
                android:fontFamily="monospace"
                android:gravity="center"
                android:shadowColor="#000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="2" />

            <View android:layout_width="44dp" android:layout_height="1dp" />
        </LinearLayout>

        <!-- Card: Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTROLS"
                android:textSize="12sp"
                android:textColor="@color/text_subtitle"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp" />

            <!-- Sensitivity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Look Sensitivity"
                    android:textColor="@color/text_light"
                    android:fontFamily="monospace"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvSensValue"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="0.15"
                    android:textColor="@color/text_gold"
                    android:fontFamily="monospace"
                    android:textSize="15sp"
                    android:gravity="end" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="30"
                android:layout_marginBottom="4dp" />

        </LinearLayout>

        <!-- Card: Graphics -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GRAPHICS"
                android:textSize="12sp"
                android:textColor="@color/text_subtitle"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp" />

            <!-- Render Distance -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Render Distance"
                    android:textColor="@color/text_light"
                    android:fontFamily="monospace"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvRenderValue"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:text="4 chunks"
                    android:textColor="@color/text_gold"
                    android:fontFamily="monospace"
                    android:textSize="15sp"
                    android:gravity="end" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekRenderDist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="6"
                android:progress="2" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
